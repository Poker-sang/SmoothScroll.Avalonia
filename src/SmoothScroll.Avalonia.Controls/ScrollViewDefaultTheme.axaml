<Styles
  x:Class="SmoothScroll.Avalonia.Controls.ScrollViewDefaultTheme"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:SmoothScroll.Avalonia.Controls">

  <Styles.Resources>
    <ResourceDictionary>
      <ControlTheme x:Key="{x:Type controls:ScrollView}" TargetType="controls:ScrollView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
          <ControlTemplate>
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
              <controls:ScrollPresenter
                Name="PART_ContentPresenter"
                Grid.Row="0"
                Grid.Column="0"
                Grid.RowSpan="2"
                Grid.ColumnSpan="2"
                Padding="{TemplateBinding Padding}"
                Background="{TemplateBinding Background}"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}"
                GestureBindings="{TemplateBinding GestureBindings}"
                HorizontalAnchorRatio="{TemplateBinding HorizontalAnchorRatio}"
                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                HorizontalScrollMode="{TemplateBinding HorizontalScrollMode}"
                VerticalScrollMode="{TemplateBinding VerticalScrollMode}"
                HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                IsScrollChainingEnabled="{TemplateBinding IsScrollChainingEnabled}"
                IsHorizontalMeasureInfinite="{TemplateBinding IsHorizontalMeasureInfinite}"
                IsVerticalMeasureInfinite="{TemplateBinding IsVerticalMeasureInfinite}"
                IsZoomEnabled="{TemplateBinding IsZoomEnabled}"
                MaxZoomFactor="{TemplateBinding MaxZoomFactor}"
                MinZoomFactor="{TemplateBinding MinZoomFactor}"
                OverscrollBounceRate="{TemplateBinding OverscrollBounceRate}"
                OverscrollElasticity="{TemplateBinding OverscrollElasticity}"
                ScrollInertiaDecayRate="{TemplateBinding ScrollInertiaDecayRate}"
                ScrollInputMultiplier="{TemplateBinding ScrollInputMultiplier}"
                ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                VerticalAnchorRatio="{TemplateBinding VerticalAnchorRatio}"
                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}"
                ZoomInertiaDecayRate="{TemplateBinding ZoomInertiaDecayRate}"
                ZoomInputMultiplier="{TemplateBinding ZoomInputMultiplier}" />
              <ScrollBar
                Name="PART_HorizontalScrollBar"
                Grid.Row="1"
                Orientation="Horizontal"
                ZIndex="1" />
              <ScrollBar
                Name="PART_VerticalScrollBar"
                Grid.Column="1"
                Orientation="Vertical"
                ZIndex="1" />
              <Panel
                x:Name="PART_ScrollBarsSeparator"
                Grid.Row="1"
                Grid.Column="1"
                Background="{DynamicResource ScrollViewerScrollBarsSeparatorBackground}"
                Opacity="0">
                <Panel.Transitions>
                  <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                  </Transitions>
                </Panel.Transitions>
              </Panel>
            </Grid>
          </ControlTemplate>
        </Setter>
        <Style Selector="^[IsExpanded=true] /template/ Panel#PART_ScrollBarsSeparator">
          <Setter Property="Opacity" Value="1" />
        </Style>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>
</Styles>
