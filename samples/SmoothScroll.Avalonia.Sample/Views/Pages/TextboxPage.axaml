<ContentPage
    x:Class="SmoothScroll.Avalonia.Sample.Views.Pages.TextboxPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:SmoothScroll.Avalonia.Sample.ViewModels"
    x:DataType="viewModels:TextBoxViewModel"
    Header="TextBox"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <Design.DataContext>
        <viewModels:TextBoxViewModel />
    </Design.DataContext>
    <TextBox Text="{Binding Text}" TextWrapping="Wrap" />
</ContentPage>
