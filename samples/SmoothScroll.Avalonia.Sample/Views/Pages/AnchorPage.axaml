<ContentPage
    x:Class="SmoothScroll.Avalonia.Sample.Views.Pages.AnchorPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SmoothScroll.Avalonia.Sample.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DataType="{x:Type local:AnchorPage}"
    Header="Anchor"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <DockPanel VerticalSpacing="5">
        <StackPanel
            DockPanel.Dock="Top"
            Orientation="Horizontal"
            Spacing="5">
            <Button Click="Button_OnClick" Content="Change items size" />
            <TextBlock>
                <Run Text="Anchor element: " />
                <Run x:Name="AnchorBox" />
                <LineBreak />
                <Run Text="ScrollChanged times：" />
                <Run x:Name="CountBox" />
            </TextBlock>
        </StackPanel>
        <ScrollViewer x:Name="ScrollViewer" ScrollChanged="ScrollViewer_OnPropertyChanged">
            <ItemsControl
                ContainerClearing="ItemsControl_OnContainerClearing"
                ContainerPrepared="ItemsControl_OnContainerPrepared"
                ItemsSource="{Binding AList}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:A}">
                        <Border
                            Height="{Binding V}"
                            BorderBrush="Blue"
                            BorderThickness="1">
                            <StackPanel
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Gray"
                                Orientation="Vertical">
                                <TextBlock Foreground="Red" Text="{Binding Index}" />
                                <TextBlock Text="{Binding V}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</ContentPage>
