<ContentPage
    x:Class="SmoothScroll.Avalonia.Sample.Views.Pages.SnapPointsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SmoothScroll.Avalonia.Sample.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DataType="{x:Type local:SnapPointsPage}"
    Header="Snap Points"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <Grid Margin="24" RowDefinitions="Auto,*" RowSpacing="16">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
            <Button Click="PreviousButton_OnClick" Content="Previous" />
            <Button Grid.Column="1" Classes="accent" Click="NextButton_OnClick" Content="Next" />
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Center"
                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                Text="Mandatory / Center" />
            <TextBlock
                Grid.Column="3"
                VerticalAlignment="Center"
                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                Text="{Binding #SnapScrollViewer.Offset, StringFormat={}{0}}" />
        </Grid>

        <Border
            Grid.Row="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
            <ScrollViewer
                x:Name="SnapScrollViewer"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalSnapPointsAlignment="Center"
                HorizontalSnapPointsType="Mandatory"
                ScrollViewer.IsScrollInertiaEnabled="True"
                VerticalContentAlignment="Top"
                VerticalScrollBarVisibility="Disabled">
                <StackPanel
                    x:Name="SnapItems"
                    Margin="24,0"
                    AreHorizontalSnapPointsRegular="True"
                    Orientation="Horizontal"
                    Spacing="24">
                    <Border Width="520" Height="336" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="8" ClipToBounds="True">
                        <Grid RowDefinitions="*,Auto">
                            <Image Source="avares://SmoothScroll.Avalonia.Sample/Assets/Images/4074.bmp" Stretch="UniformToFill" />
                            <Border Grid.Row="1" Padding="16" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                <TextBlock FontSize="20" Text="01" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Width="520" Height="336" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="8" ClipToBounds="True">
                        <Grid RowDefinitions="*,Auto">
                            <Image Source="avares://SmoothScroll.Avalonia.Sample/Assets/Images/4074.bmp" RenderTransformOrigin="0.25,0.5" Stretch="UniformToFill">
                                <Image.RenderTransform>
                                    <ScaleTransform ScaleX="1.25" ScaleY="1.25" />
                                </Image.RenderTransform>
                            </Image>
                            <Border Grid.Row="1" Padding="16" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                <TextBlock FontSize="20" Text="02" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Width="520" Height="336" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="8" ClipToBounds="True">
                        <Grid RowDefinitions="*,Auto">
                            <Image Source="avares://SmoothScroll.Avalonia.Sample/Assets/Images/4074.bmp" RenderTransformOrigin="0.75,0.5" Stretch="UniformToFill">
                                <Image.RenderTransform>
                                    <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
                                </Image.RenderTransform>
                            </Image>
                            <Border Grid.Row="1" Padding="16" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                <TextBlock FontSize="20" Text="03" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Width="520" Height="336" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="8" ClipToBounds="True">
                        <Grid RowDefinitions="*,Auto">
                            <Image Source="avares://SmoothScroll.Avalonia.Sample/Assets/Images/4074.bmp" RenderTransformOrigin="0.5,0.75" Stretch="UniformToFill">
                                <Image.RenderTransform>
                                    <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
                                </Image.RenderTransform>
                            </Image>
                            <Border Grid.Row="1" Padding="16" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                <TextBlock FontSize="20" Text="04" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Width="520" Height="336" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="8" ClipToBounds="True">
                        <Grid RowDefinitions="*,Auto">
                            <Image Source="avares://SmoothScroll.Avalonia.Sample/Assets/Images/4074.bmp" RenderTransformOrigin="0.5,0.25" Stretch="UniformToFill">
                                <Image.RenderTransform>
                                    <ScaleTransform ScaleX="2" ScaleY="2" />
                                </Image.RenderTransform>
                            </Image>
                            <Border Grid.Row="1" Padding="16" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                <TextBlock FontSize="20" Text="05" />
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</ContentPage>
